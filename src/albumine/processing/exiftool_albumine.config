# ExifTool configuration for AlbuMine.
#
# Defines a custom XMP namespace (prefix "albumine") so AlbuMine can record
# its own provenance data — date confidence, the AI model used, processing
# version, source files — directly inside the image's XMP packet without
# clashing with standard tags.
#
# Passed to exiftool via:  exiftool -config exiftool_albumine.config ...

%Image::ExifTool::UserDefined = (
    'Image::ExifTool::XMP::Main' => {
        albumine => {
            SubDirectory => {
                TagTable => 'Image::ExifTool::UserDefined::albumine',
            },
        },
    },
);

%Image::ExifTool::UserDefined::albumine = (
    GROUPS    => { 0 => 'XMP', 1 => 'XMP-albumine', 2 => 'Image' },
    NAMESPACE => { 'albumine' => 'http://ns.albumine.app/1.0/' },
    WRITABLE  => 'string',

    DateConfidence    => { },
    DatePrecision     => { },
    DateOriginalText  => { },
    AiProvider        => { },
    AiModel           => { },
    EnhancementLevel  => { },
    ProcessingVersion => { },
    SourceFiles       => { List => 'Bag' },
);

1;  # config files must return a true value
