# Copy to .env for local (non-Docker) development. All variables are optional;
# the defaults in src/albumine/config.py work for a standard setup.

# Web UI
# ALBUMINE_WEBUI_PORT=8765

# Task queue
# ALBUMINE_REDIS_URL=redis://localhost:6379

# AI backend: ollama | anthropic | openai_compat
# ALBUMINE_AI_PROVIDER=ollama
# ALBUMINE_OLLAMA_HOST=http://localhost:11434
# ALBUMINE_OLLAMA_VISION_MODEL=llava
# ALBUMINE_ANTHROPIC_API_KEY=
# ALBUMINE_ANTHROPIC_MODEL=claude-opus-4-7

# Image enhancement: none | basic | enhance | restore
# ALBUMINE_DEFAULT_ENHANCEMENT_LEVEL=basic
# 'enhance' / 'restore' need external CLI tools (not bundled). Point these at
# the binaries; contract is: <bin> -i <input> -o <output> [extra args].
# ALBUMINE_REALESRGAN_BIN=/usr/local/bin/realesrgan-ncnn-vulkan
# ALBUMINE_REALESRGAN_ARGS=-s 4 -n realesrgan-x4plus
# ALBUMINE_GFPGAN_BIN=
# ALBUMINE_GFPGAN_ARGS=

# UI language (start value; changeable later in the web settings panel).
# Shipped: de en fr es it pt nl pl ru uk cs sv tr zh-Hans ja ko
# ALBUMINE_UI_LANGUAGE=de

# Logging
# ALBUMINE_LOG_LEVEL=INFO
# ALBUMINE_LOG_JSON=true

# Volume paths (only override for non-Docker runs)
# ALBUMINE_INPUT_DIR=/input
# ALBUMINE_OUTPUT_DIR=/output
# ALBUMINE_CONFIG_DIR=/config
